# AWS Configuration
AWS_REGION=us-east-1
AWS_INSTANCE_ID=i-xxxxxxxxxxxxxxxxx
AWS_KEY_FILE=/path/to/your-key.pem
AWS_SSH_USER=ec2-user
AWS_INSTANCE_TYPE=r7i.2xlarge

# Extraction Configuration
CANVAS_DOMAIN=canvas.instructure.com
EXTRACT_COURSES=course_id_1,course_id_2
DOWNLOAD_FILES=true
PARALLEL_COURSES=20

# Concurrency Settings (auto-detected based on AWS_INSTANCE_TYPE if not set)
# MAX_CONCURRENCY=100

# Streaming Server
STREAMING_PORT=3002
REMOTE_DEPLOY_DIR=~/streaming-server

# CloudWatch Logging
CLOUDWATCH_LOG_GROUP=/aws/canvas-extraction/runs
CLOUDWATCH_LOG_STREAM_PREFIX=extraction-run

# Cookie Storage
COOKIES_DIR=./cookies
