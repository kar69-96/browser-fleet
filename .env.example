# =============================================================================
# Target Site Configuration
# =============================================================================
TARGET_URL=https://your-site.com
TARGET_NAME=YourApp

# Login detection: comma-separated URL patterns
LOGIN_SUCCESS_PATTERNS=/dashboard,/home
LOGIN_EXCLUDE_PATTERNS=/login,/auth,/sso,/fedauth

# Post-login (optional): navigate to profile page to extract username
# POST_LOGIN_URL=https://your-site.com/profile/settings
# USERNAME_SELECTORS=input[name="username"],#user-display-name

# =============================================================================
# AWS Configuration
# =============================================================================
AWS_REGION=us-east-1
EC2_INSTANCE_TYPE=t3.small
EC2_AMI_ID=ami-xxxxxxxxx
EC2_KEY_PAIR_NAME=your-key-pair
EC2_SECURITY_GROUPS=sg-xxxxxxxxx
EC2_SUBNET_ID=subnet-xxxxxxxxx
# EC2_IAM_PROFILE=your-instance-profile  # Optional

# =============================================================================
# Scaling Configuration
# =============================================================================
MIN_WARM_INSTANCES=1
MAX_INSTANCES=10
MAX_SESSIONS_PER_INSTANCE=3

# Timeouts (milliseconds)
IDLE_TIMEOUT_MS=300000          # 5 min - hibernate idle instances
WARM_TIMEOUT_MS=900000          # 15 min - max warm without activity
HIBERNATE_TIMEOUT_MS=3600000    # 1 hour - terminate hibernated instances

# Burst scaling
BURST_SCALE_THRESHOLD=2         # Scale up when 2+ users queued
BURST_SCALE_COUNT=1             # Number of instances to add per burst

# =============================================================================
# Supabase (State Store)
# =============================================================================
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJhbGci...

# =============================================================================
# API Configuration
# =============================================================================
API_BASE_URL=https://your-api.com
INTERNAL_API_KEY=your-secret-key
EC2_MANAGER_ENABLED=true
EC2_MANAGER_URL=https://your-api.com

# =============================================================================
# Cloudflare Tunnel
# =============================================================================
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token
CLOUDFLARE_TUNNEL_URL=https://login.your-domain.com

# =============================================================================
# Streaming Server
# =============================================================================
STREAMING_PORT=3002
STREAMING_SERVER_URL=https://login.your-domain.com  # Fallback for static mode
SERVICE_TAG=streaming-auth

# =============================================================================
# Extraction Manager
# =============================================================================
EXTRACTION_INSTANCE_ID=i-xxxxxxxxx
EXTRACTION_SCRIPT_PATH=/home/ec2-user/extraction
MAX_EXTRACTION_TIME_MS=10800000     # 3 hours
EXTRACTION_IDLE_TIMEOUT_MS=900000   # 15 min
